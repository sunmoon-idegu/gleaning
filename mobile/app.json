{
  "expo": {
    "name": "Gleaning",
    "slug": "gleaning",
    "version": "1.0.0",
    "scheme": "io.gleaning.app",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.gleaning.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Used to pick a photo of a page to extract a quote.",
        "NSCameraUsageDescription": "Used to take a photo of a page to extract a quote.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to pick a photo of a page to extract a quote.",
          "cameraPermission": "Used to take a photo of a page to extract a quote."
        }
      ],
      "expo-localization",
      "expo-apple-authentication"
    ],
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "io.gleaning.app"
    },
    "extra": {
      "eas": {
        "projectId": "eafc582b-0ac2-477e-8553-9da44601ca56"
      }
    },
    "owner": "yuming-team"
  }
}
